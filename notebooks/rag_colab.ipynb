    "    \"# Also save in Colab\\n\",\n",
    "    \"from google.colab import files\\n\",\n",
    "    \"files.download(output_file)\\n\",\n",
    "    \"print(f\\\"📥 Downloaded {output_file}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 9: Detailed Analysis\\n\",\n",
    "    \"\\n\",\n",
