    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Initialize RAG pipeline\\n\",\n",
    "    \"print(\\\"Initializing RAG Pipeline...\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"rag = RAGPipeline(\\n\",\n",
    "    \"    data_dir=\\\"data\\\",\\n\",\n",
    "    \"    vector_store_dir=\\\"vector_store\\\",\\n\",\n",
    "    \"    embedding_model=\\\"sentence-transformers/all-MiniLM-L6-v2\\\",\\n\",\n",
    "    \"    llm_model=\\\"mistral\\\",  # Requires Ollama running locally\\n\",\n",
    "    \"    top_k=5,\\n\",\n",
    "    \"    chunk_size=500,\\n\",\n",
    "    \"    chunk_overlap=100\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✅ RAG Pipeline initialized\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Check if index already exists\\n\",\n",
    "    \"if rag.is_indexed():\\n\",\n",
    "    \"    print(\\\"Vector store found. Loading...\\\")\\n\",\n",
