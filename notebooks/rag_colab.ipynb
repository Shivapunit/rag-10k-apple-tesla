    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Display detailed results for each question\\n\",\n",
    "    \"for result in results:\\n\",\n",
    "    \"    print(f\\\"\\\\n{'='*80}\\\")\\n\",\n",
    "    \"    print(f\\\"Question {result['question_id']}\\\")\\n\",\n",
    "    \"    print(f\\\"{'='*80}\\\")\\n\",\n",
    "    \"    print(f\\\"\\\\nAnswer:\\\\n{result['answer']}\\\")\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    if result['sources']:\\n\",\n",
    "    \"        print(f\\\"\\\\nSources: ({len(result['sources'])} document(s))\\\")\\n\",\n",
    "    \"        for i, source in enumerate(result['sources'], 1):\\n\",\n",
    "    \"            print(f\\\"  {i}. {source}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(f\\\"\\\\nSources: None\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 10: Evaluation & Comparison to Ground Truth\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Ground truth answers for reference\\n\",\n",
    "    \"ground_truth = {\\n\",\n",
    "    \"    1: {\\\"answer\\\": \\\"$391,036 million\\\", \\\"source\\\": \\\"Apple 10-K, Item 8, p. 282\\\"},\\n\",\n",
    "    \"    2: {\\\"answer\\\": \\\"15,115,823,000 shares\\\", \\\"source\\\": \\\"Apple 10-K, first paragraph\\\"},\\n\",\n",
    "    \"    3: {\\\"answer\\\": \\\"$96,662 million\\\", \\\"source\\\": \\\"Apple 10-K, Item 8, Note 9, p. 394\\\"},\\n\",\n",
    "    \"    4: {\\\"answer\\\": \\\"November 1, 2024\\\", \\\"source\\\": \\\"Apple 10-K, Signature page\\\"},\\n\",\n",
    "    \"    5: {\\\"answer\\\": \\\"No\\\", \\\"source\\\": \\\"Apple 10-K, Item 1B, p. 176\\\"},\\n\",\n",
    "    \"    6: {\\\"answer\\\": \\\"$96,773 million\\\", \\\"source\\\": \\\"Tesla 10-K, Item 7\\\"},\\n\",\n",
    "    \"    7: {\\\"answer\\\": \\\"~84%\\\", \\\"source\\\": \\\"Tesla 10-K, Item 7\\\"},\\n\",\n",
    "    \"    8: {\\\"answer\\\": \\\"Central to strategy, innovation, leadership\\\", \\\"source\\\": \\\"Tesla 10-K, Item 1A\\\"},\\n\",\n",
    "    \"    9: {\\\"answer\\\": \\\"Model S, 3, X, Y, Cybertruck\\\", \\\"source\\\": \\\"Tesla 10-K, Item 1\\\"},\\n\",\n",
    "    \"    10: {\\\"answer\\\": \\\"Finance solar systems\\\", \\\"source\\\": \\\"Tesla 10-K, Item 7\\\"},\\n\",\n",
    "    \"    11: {\\\"answer\\\": \\\"Not answerable (out-of-scope)\\\", \\\"source\\\": \\\"N/A\\\"},\\n\",\n",
    "    \"    12: {\\\"answer\\\": \\\"Not answerable (out-of-scope)\\\", \\\"source\\\": \\\"N/A\\\"},\\n\",\n",
    "    \"    13: {\\\"answer\\\": \\\"Not answerable (out-of-scope)\\\", \\\"source\\\": \\\"N/A\\\"},\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n📚 Ground Truth Answers:\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 80)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for q_id, truth in ground_truth.items():\\n\",\n",
