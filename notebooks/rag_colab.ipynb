    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Display results as table\\n\",\n",
    "    \"results_df = pd.DataFrame([\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"Q#\\\": r[\\\"question_id\\\"],\\n\",\n",
