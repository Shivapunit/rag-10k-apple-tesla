    "    \"    print(f\\\"\\\\nQ{q_id}:\\\")\\n\",\n",
    "    \"    print(f\\\"  Expected: {truth['answer']}\\\")\\n\",\n",
    "    \"    print(f\\\"  Got: {our_answer[:100]}...\\\" if len(our_answer) > 100 else f\\\"  Got: {our_answer}\\\")\\n\",\n",
    "    \"    print(f\\\"  Source: {truth['source']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
