    "    \"    print(\\\"Building vector index from PDFs...\\\")\\n\",\n",
    "    \"    print(\\\"This may take 2-5 minutes...\\\\n\\\")\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    success = rag.build_index()\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    if success:\\n\",\n",
    "    \"        print(f\\\"\\\\n✅ Index built successfully!\\\")\\n\",\n",
    "    \"        print(f\\\"Total chunks: {rag.get_chunk_count()}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"❌ Index building failed. Check error messages above.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 6: Test Single Question\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Test with a sample question\\n\",\n",
    "    \"test_query = \\\"What was Apple's total revenue for the fiscal year ended September 28, 2024?\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Query: {test_query}\\\\n\\\")\\n\",\n",
    "    \"print(\\\"Generating answer...\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"result = rag.answer_question(test_query, top_k=5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Answer:\\\")\\n\",\n",
    "    \"print(\\\"-\\\" * 80)\\n\",\n",
    "    \"print(result[\\\"answer\\\"])\\n\",\n",
    "    \"print(\\\"-\\\" * 80)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if result[\\\"sources\\\"]:\\n\",\n",
    "    \"    print(\\\"\\\\nSources:\\\")\\n\",\n",
    "    \"    for i, source in enumerate(result[\\\"sources\\\"], 1):\\n\",\n",
    "    \"        print(f\\\"  {i}. {source['document']} - {source['item']} - p. {source['page']}\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"\\\\nNo sources found.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 7: Run All 13 Test Questions\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Define the 13 test questions\\n\",\n",
    "    \"test_questions = [\\n\",\n",
    "    \"    {\\\"question_id\\\": 1, \\\"question\\\": \\\"What was Apple's total revenue for the fiscal year ended September 28, 2024?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 2, \\\"question\\\": \\\"How many shares of common stock were issued and outstanding as of October 18, 2024?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 3, \\\"question\\\": \\\"What is the total amount of term debt (current + non-current) reported by Apple as of September 28, 2024?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 4, \\\"question\\\": \\\"On what date was Apple's 10-K report for 2024 signed and filed with the SEC?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 5, \\\"question\\\": \\\"Does Apple have any unresolved staff comments from the SEC as of this filing? How do you know?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 6, \\\"question\\\": \\\"What was Tesla's total revenue for the year ended December 31, 2023?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 7, \\\"question\\\": \\\"What percentage of Tesla's total revenue in 2023 came from Automotive Sales (excluding Leasing)?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 8, \\\"question\\\": \\\"What is the primary reason Tesla states for being highly dependent on Elon Musk?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 9, \\\"question\\\": \\\"What types of vehicles does Tesla currently produce and deliver?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 10, \\\"question\\\": \\\"What is the purpose of Tesla's 'lease pass-through fund arrangements'?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 11, \\\"question\\\": \\\"What is Tesla's stock price forecast for 2025?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 12, \\\"question\\\": \\\"Who is the CFO of Apple as of 2025?\\\"},\\n\",\n",
    "    \"    {\\\"question_id\\\": 13, \\\"question\\\": \\\"What color is Tesla's headquarters painted?\\\"},\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Running {len(test_questions)} test questions...\\\\n\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 80)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Process all questions and collect results\\n\",\n",
    "    \"results = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i, test_q in enumerate(test_questions, 1):\\n\",\n",
    "    \"    print(f\\\"\\\\n[{i}/13] Question ID {test_q['question_id']}: {test_q['question'][:60]}...\\\")\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        result = rag.answer_question(test_q['question'], top_k=5)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        formatted_result = {\\n\",\n",
    "    \"            \\\"question_id\\\": test_q['question_id'],\\n\",\n",
    "    \"            \\\"answer\\\": result[\\\"answer\\\"],\\n\",\n",
    "    \"            \\\"sources\\\": [f\\\"{s['document']} - {s['item']} - p. {s['page']}\\\" for s in result[\\\"sources\\\"]]\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"        results.append(formatted_result)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # Preview answer\\n\",\n",
    "    \"        answer_preview = result[\\\"answer\\\"][:100] + \\\"...\\\" if len(result[\\\"answer\\\"]) > 100 else result[\\\"answer\\\"]\\n\",\n",
    "    \"        print(f\\\"  Answer: {answer_preview}\\\")\\n\",\n",
    "    \"        print(f\\\"  Sources: {len(result['sources'])} document(s)\\\")\\n\",\n",
    "    \"        \\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"  ❌ Error: {str(e)}\\\")\\n\",\n",
    "    \"        results.append({\\n\",\n",
    "    \"            \\\"question_id\\\": test_q['question_id'],\\n\",\n",
    "    \"            \\\"answer\\\": f\\\"Error: {str(e)}\\\",\\n\",\n",
    "    \"            \\\"sources\\\": []\\n\",\n",
    "    \"        })\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n\\\" + \\\"=\\\" * 80)\\n\",\n",
    "    \"print(f\\\"\\\\n✅ Processed all {len(results)} questions!\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 8: View & Export Results\"\n",
